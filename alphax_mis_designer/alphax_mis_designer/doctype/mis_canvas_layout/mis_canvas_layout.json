{
  "doctype": "DocType",
  "name": "MIS Canvas Layout",
  "module": "AlphaX MIS Designer",
  "autoname": "format:MIS-CANVAS-{YYYY}-{MM}-{####}",
  "title_field": "layout_title",
  "fields": [
    {
      "fieldname": "layout_title",
      "fieldtype": "Data",
      "label": "Layout Title",
      "reqd": 1
    },
    {
      "fieldname": "user",
      "fieldtype": "Link",
      "label": "User",
      "options": "User",
      "reqd": 1
    },
    {
      "fieldname": "profile",
      "fieldtype": "Select",
      "label": "Profile",
      "options": "CEO\nCFO\nDepartment Head",
      "reqd": 1
    },
    {
      "fieldname": "visual_template",
      "fieldtype": "Link",
      "label": "Visual Template",
      "options": "MIS Visual Template",
      "reqd": 1
    },
    {
      "fieldname": "layout_json",
      "fieldtype": "Code",
      "label": "Layout JSON",
      "options": "JSON",
      "reqd": 1
    },
    {
      "fieldname": "is_default",
      "fieldtype": "Check",
      "label": "Default for profile",
      "default": 0
    },
    {
      "fieldname": "is_public",
      "fieldtype": "Check",
      "label": "Public",
      "default": 0
    }
  ],
  "permissions": [
    {
      "role": "System Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Accounts Manager",
      "read": 1,
      "write": 1,
      "create": 1,
      "delete": 1
    },
    {
      "role": "Accounts User",
      "read": 1,
      "write": 0,
      "create": 0,
      "delete": 0
    }
  ]
}